d.en;\n  document.getElementById('nav-bc').textContent = '\/ '+d.en;\n  document.getElementById('sb-loc').textContent = d.jp;\n  document.getElementById('sb-floor').textContent = d.floor;\n  document.getElementById('ddwrap').classList.remove('dd-open');\n}\n\nfunction transitionTo(name){\n  const sl = document.getElementById('speed-lines');\n  sl.classList.add('active');\n  setTimeout(()=>{ goScene(name); sl.classList.remove('active'); }, 220);\n}\n\nfunction toggleDD(){\n  document.getElementById('ddwrap').classList.toggle('dd-open');\n}\ndocument.addEventListener('click',e=>{\n  if(!e.target.closest('#ddwrap')) document.getElementById('ddwrap').classList.remove('dd-open');\n});\n\n\/* ─────────────────────────────────────\n   POPUP\n───────────────────────────────────── *\/\nfunction closePopup(){\n  document.getElementById('popup-overlay').style.display='none';\n}\n\n\/* ─────────────────────────────────────\n   VIDEO MODAL\n───────────────────────────────────── *\/\nfunction openVid(id,emoji,title,desc,cap){\n  document.getElementById('vm-title').textContent = title;\n  document.getElementById('vm-title2').textContent = title;\n  document.getElementById('vm-emoji').textContent = emoji;\n  document.getElementById('vm-sub').textContent = desc;\n  document.getElementById('vm-cap').textContent = cap + ' — swap openVid() with your video embed.';\n  document.getElementById('vmodal').classList.add('open');\n}\nfunction closeVid(){ document.getElementById('vmodal').classList.remove('open'); }\n\n\/* ─────────────────────────────────────\n   CURSOR TRACKER\n───────────────────────────────────── *\/\ndocument.addEventListener('mousemove',e=>{\n  document.getElementById('sb-cursor').textContent =\n    'x:'+String(Math.round(e.clientX)).padStart(3,'0')+\n    ' y:'+String(Math.round(e.clientY)).padStart(3,'0');\n});\n\n\/* ─────────────────────────────────────\n   CANVAS DRAWING ENGINE\n───────────────────────────────────── *\/\nfunction setupCanvas(id, drawFn){\n  const canvas = document.getElementById(id);\n  if(!canvas) return;\n  const parent = canvas.parentElement;\n  function resize(){\n    canvas.width = parent.offsetWidth;\n    canvas.height = parent.offsetHeight;\n    drawFn(canvas.getContext('2d'), canvas.width, canvas.height);\n  }\n  resize();\n  new ResizeObserver(resize).observe(parent);\n}\n\n\/* ─── DRAW HELPERS ─── *\/\nfunction outline(ctx, fn, lw=3){\n  ctx.save(); ctx.strokeStyle='#0a0a12'; ctx.lineWidth=lw; fn(); ctx.stroke(); ctx.restore();\n}\nfunction fill(ctx, color, fn){ ctx.save(); ctx.fillStyle=color; fn(); ctx.fill(); ctx.restore(); }\nfunction strokeRect(ctx,x,y,w,h,sw=3){ctx.strokeStyle='#0a0a12';ctx.lineWidth=sw;ctx.strokeRect(x,y,w,h)}\nfunction line(ctx,x1,y1,x2,y2,color='#0a0a12',lw=2){ctx.save();ctx.strokeStyle=color;ctx.lineWidth=lw;ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();ctx.restore()}\nfunction mangaText(ctx,text,x,y,size,color='#0a0a12'){ctx.save();ctx.font=`900 ${size}px 'Bebas Neue',sans-serif`;ctx.fillStyle=color;ctx.fillText(text,x,y);ctx.restore()}\n\n\/* ═══════════════════════════════════\n   SCENE DRAWS\n═══════════════════════════════════ *\/\n\n\/* ── EXTERIOR ── *\/\nfunction drawExterior(ctx, W, H){\n  \/\/ sky — manga dusky\n  const skyGrad = ctx.createLinearGradient(0,0,0,H*.55);\n  skyGrad.addColorStop(0,'#0a0820');\n  skyGrad.addColorStop(0.5,'#1a1045');\n  skyGrad.addColorStop(1,'#2a1a55');\n  ctx.fillStyle=skyGrad; ctx.fillRect(0,0,W,H*.55);\n\n  \/\/ halftone dot sky texture\n  ctx.save(); ctx.globalAlpha=0.07;\n  for(let y=0;y<H*.55;y+=8) for(let x=0;x<W;x+=8){\n    ctx.fillStyle='#fff'; ctx.beginPath(); ctx.arc(x,y,1,0,Math.PI*2); ctx.fill();\n  }\n  ctx.restore();\n\n  \/\/ moon\n  ctx.save(); ctx.fillStyle='#f5f2ea'; ctx.beginPath(); ctx.arc(W*.82,H*.08,W*.04,0,Math.PI*2); ctx.fill(); ctx.restore();\n  ctx.save(); ctx.fillStyle='#1a1045'; ctx.beginPath(); ctx.arc(W*.84,H*.07,W*.033,0,Math.PI*2); ctx.fill(); ctx.restore();\n\n  \/\/ stars\n  ctx.save(); ctx.fillStyle='#fff';\n  const starPos=[[.1,.05],[.2,.12],[.35,.07],[.5,.04],[.6,.1],[.7,.06],[.25,.16],[.45,.14],[.65,.18],[.15,.2],[.78,.12],[.9,.09],[.05,.15]];\n  starPos.forEach(([sx,sy])=>{ctx.globalAlpha=Math.random()*.5+.3;ctx.beginPath();ctx.arc(W*sx,H*sy,1.5,0,Math.PI*2);ctx.fill();});\n  ctx.restore();\n\n  \/\/ distant city skyline\n  ctx.save(); ctx.fillStyle='#160e30';\n  const skyline=[[0,.32],[.05,.28],[.08,.26],[.1,.3],[.14,.22],[.17,.25],[.2,.28],[.22,.2],[.25,.22],[.28,.25],[.32,.3],[.36,.18],[.4,.22],[.43,.28],[.46,.24],[.5,.3],[.55,.26],[.58,.22],[.62,.28],[.65,.2],[.68,.24],[.72,.3],[.76,.26],[.8,.22],[.84,.28],[.88,.24],[.92,.3],[.95,.26],[.98,.22],[1,.3],[1,.55],[0,.55]];\n  ctx.beginPath();\n  skyline.forEach(([sx,sy],i)=>{ if(i===0)ctx.moveTo(W*sx,H*sy); else ctx.lineTo(W*sx,H*sy); });\n  ctx.closePath(); ctx.fill(); ctx.restore();\n\n  \/\/ ground \/ road\n  const groundGrad = ctx.createLinearGradient(0,H*.54,0,H);\n  groundGrad.addColorStop(0,'#0f1408'); groundGrad.addColorStop(1,'#1a1e0f');\n  ctx.fillStyle=groundGrad; ctx.fillRect(0,H*.54,W,H*.46);\n\n  \/\/ road markings\n  ctx.save(); ctx.fillStyle='#f5f2ea'; ctx.globalAlpha=0.25;\n  for(let x=0;x<W;x+=W*.1){ ctx.fillRect(x,H*.58,W*.06,H*.012); }\n  ctx.restore();\n\n  \/\/ pavement \/ walkway\n  ctx.fillStyle='#1e2218'; ctx.fillRect(0,H*.54,W,H*.08);\n  line(ctx,0,H*.62,W,H*.62,'#0a0a12',3);\n\n  \/\/ ── JAPANESE HOUSE ──\n  const houseX = W*.28, houseW = W*.44, houseH = H*.52, houseY = H*.08;\n\n  \/\/ ROOF — traditional curved manga style\n  ctx.save();\n  \/\/ main roof body\n  ctx.fillStyle='#1a1830';\n  ctx.beginPath();\n  ctx.moveTo(houseX-W*.06, houseY+H*.18);\n  ctx.lineTo(houseX+houseW*.5, houseY);\n  ctx.lineTo(houseX+houseW+W*.06, houseY+H*.18);\n  ctx.lineTo(houseX+houseW+W*.06, houseY+H*.22);\n  ctx.lineTo(houseX-W*.06, houseY+H*.22);\n  ctx.closePath(); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=3; ctx.stroke();\n  \/\/ roof ridge tiles\n  ctx.fillStyle='#241e40';\n  for(let tx=houseX-W*.05; tx<houseX+houseW+W*.05; tx+=W*.025){\n    ctx.fillRect(tx,houseY+H*.005,W*.022,H*.012);\n    ctx.strokeStyle='#0a0a12';ctx.lineWidth=1;ctx.strokeRect(tx,houseY+H*.005,W*.022,H*.012);\n  }\n  \/\/ roof shading lines (manga style)\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=1; ctx.globalAlpha=0.3;\n  for(let i=0;i<10;i++){\n    ctx.beginPath();\n    ctx.moveTo(houseX+houseW*.5,houseY);\n    ctx.lineTo(houseX-W*.06+i*(houseW+W*.12)\/10,houseY+H*.2);\n    ctx.stroke();\n  }\n  ctx.restore();\n\n  \/\/ house walls\n  ctx.fillStyle='#e8e4d8'; ctx.fillRect(houseX,houseY+H*.16,houseW,H*.36);\n  strokeRect(ctx,houseX,houseY+H*.16,houseW,H*.36,3);\n\n  \/\/ wall cross-hatching (manga shading, left side)\n  ctx.save(); ctx.strokeStyle='#0a0a12'; ctx.lineWidth=.5; ctx.globalAlpha=0.08;\n  for(let i=0;i<12;i++){\n    ctx.beginPath();ctx.moveTo(houseX,houseY+H*.16+i*H*.03);ctx.lineTo(houseX+houseW*.3,houseY+H*.16+i*H*.03);ctx.stroke();\n  }\n  ctx.restore();\n\n  \/\/ SHOJI WINDOWS (Japanese lattice windows)\n  const winY = houseY+H*.2;\n  const windows = [{x:houseX+houseW*.06,w:houseW*.18},{x:houseX+houseW*.32,w:houseW*.18},{x:houseX+houseW*.58,w:houseW*.15}];\n  windows.forEach(win=>{\n    \/\/ window frame\n    ctx.fillStyle='#f0ede4'; ctx.fillRect(win.x,winY,win.w,H*.14);\n    strokeRect(ctx,win.x,winY,win.w,H*.14,3);\n    \/\/ shoji grid — vertical\n    for(let gx=win.x+win.w*.25;gx<win.x+win.w;gx+=win.w*.25) line(ctx,gx,winY,gx,winY+H*.14,'#0a0a12',1.5);\n    \/\/ shoji grid — horizontal\n    line(ctx,win.x,winY+H*.047,win.x+win.w,winY+H*.047,'#0a0a12',1.5);\n    line(ctx,win.x,winY+H*.094,win.x+win.w,winY+H*.094,'#0a0a12',1.5);\n    \/\/ night glow through window\n    ctx.save(); ctx.fillStyle='#ffdd88'; ctx.globalAlpha=0.25;\n    ctx.fillRect(win.x+2,winY+2,win.w-4,H*.14-4); ctx.restore();\n  });\n\n  \/\/ FRONT DOOR — wide Japanese style\n  const doorX = houseX+houseW*.38, doorW = houseW*.22, doorH = H*.24, doorY = houseY+H*.28;\n  ctx.fillStyle='#1a1020'; ctx.fillRect(doorX,doorY,doorW,doorH);\n  strokeRect(ctx,doorX,doorY,doorW,doorH,3);\n  \/\/ door panels\n  line(ctx,doorX+doorW*.5,doorY,doorX+doorW*.5,doorY+doorH,'#0a0a12',2);\n  line(ctx,doorX,doorY+doorH*.35,doorX+doorW,doorY+doorH*.35,'#0a0a12',2);\n  line(ctx,doorX,doorY+doorH*.7,doorX+doorW,doorY+doorH*.7,'#0a0a12',2);\n  \/\/ door handle\n  ctx.save(); ctx.fillStyle='#c8a832';\n  ctx.beginPath(); ctx.arc(doorX+doorW*.62,doorY+doorH*.55,W*.008,0,Math.PI*2); ctx.fill();\n  ctx.beginPath(); ctx.arc(doorX+doorW*.38,doorY+doorH*.55,W*.008,0,Math.PI*2); ctx.fill();\n  ctx.restore();\n  \/\/ door glow from inside\n  ctx.save(); ctx.fillStyle='#ffcc66'; ctx.globalAlpha=0.08;\n  ctx.fillRect(doorX,doorY,doorW,doorH); ctx.restore();\n\n  \/\/ PORCH \/ GENKAN step\n  ctx.fillStyle='#c8b896'; ctx.fillRect(houseX+houseW*.3,houseY+H*.52,houseW*.4,H*.04);\n  strokeRect(ctx,houseX+houseW*.3,houseY+H*.52,houseW*.4,H*.04,2);\n\n  \/\/ stone path to door\n  ctx.save();\n  const stones=[{x:.44,s:.04},{x:.47,s:.035},{x:.45,s:.03},{x:.46,s:.04},{x:.44,s:.03}];\n  stones.forEach((st,i)=>{\n    ctx.fillStyle=i%2===0?'#b8b49a':'#ccc8b0';\n    ctx.fillRect(W*st.x,H*(.59+i*.03),W*st.s*1.5,H*.025);\n    ctx.strokeStyle='#0a0a12'; ctx.lineWidth=1; ctx.strokeRect(W*st.x,H*(.59+i*.03),W*st.s*1.5,H*.025);\n  });\n  ctx.restore();\n\n  \/\/ lantern post\n  ctx.fillStyle='#241e30'; ctx.fillRect(W*.38,H*.52,W*.012,H*.14);\n  ctx.fillStyle='#c8a832'; ctx.fillRect(W*.373,H*.52,W*.026,H*.048);\n  strokeRect(ctx,W*.373,H*.52,W*.026,H*.048,2);\n  ctx.save(); ctx.fillStyle='#fff4aa'; ctx.globalAlpha=0.6;\n  ctx.fillRect(W*.374,H*.521,W*.024,H*.045); ctx.restore();\n  \/\/ lantern glow\n  ctx.save(); ctx.fillStyle='#ffcc44'; ctx.globalAlpha=0.08;\n  ctx.beginPath(); ctx.arc(W*.386,H*.544,W*.04,0,Math.PI*2); ctx.fill(); ctx.restore();\n\n  \/\/ ── BMW E30 ──\n  const carX = W*.03, carY = H*.58, carW = W*.28, carH = H*.2;\n\n  \/\/ shadow\n  ctx.save(); ctx.fillStyle='#0a0a12'; ctx.globalAlpha=0.4;\n  ctx.beginPath(); ctx.ellipse(carX+carW*.5,carY+carH,carW*.45,carH*.08,0,0,Math.PI*2); ctx.fill();\n  ctx.restore();\n\n  \/\/ car body — E30 BMW silhouette\n  \/\/ main body\n  ctx.fillStyle='#1a1a2a';\n  ctx.beginPath();\n  ctx.moveTo(carX+carW*.05,carY+carH*.7);\n  ctx.lineTo(carX+carW*.12,carY+carH*.4);\n  ctx.lineTo(carX+carW*.28,carY+carH*.15); \/\/ front windshield\n  ctx.lineTo(carX+carW*.52,carY+carH*.1);  \/\/ roof\n  ctx.lineTo(carX+carW*.72,carY+carH*.18); \/\/ rear screen\n  ctx.lineTo(carX+carW*.85,carY+carH*.4);\n  ctx.lineTo(carX+carW*.95,carY+carH*.65);\n  ctx.lineTo(carX+carW*.95,carY+carH*.75);\n  ctx.lineTo(carX+carW*.05,carY+carH*.75);\n  ctx.closePath(); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=3; ctx.stroke();\n\n  \/\/ body color stripe\n  ctx.save(); ctx.fillStyle='#252540'; ctx.globalAlpha=0.8;\n  ctx.beginPath();\n  ctx.moveTo(carX+carW*.06,carY+carH*.72);\n  ctx.lineTo(carX+carW*.06,carY+carH*.6);\n  ctx.lineTo(carX+carW*.94,carY+carH*.6);\n  ctx.lineTo(carX+carW*.94,carY+carH*.72);\n  ctx.closePath(); ctx.fill(); ctx.restore();\n\n  \/\/ windows\n  ctx.fillStyle='#0a1a2a';\n  \/\/ windshield\n  ctx.beginPath();\n  ctx.moveTo(carX+carW*.14,carY+carH*.42);\n  ctx.lineTo(carX+carW*.28,carY+carH*.18);\n  ctx.lineTo(carX+carW*.5,carY+carH*.13);\n  ctx.lineTo(carX+carW*.5,carY+carH*.42);\n  ctx.closePath(); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=2; ctx.stroke();\n  \/\/ rear window\n  ctx.beginPath();\n  ctx.moveTo(carX+carW*.52,carY+carH*.13);\n  ctx.lineTo(carX+carW*.7,carY+carH*.2);\n  ctx.lineTo(carX+carW*.82,carY+carH*.42);\n  ctx.lineTo(carX+carW*.52,carY+carH*.42);\n  ctx.closePath(); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=2; ctx.stroke();\n  \/\/ window reflection\n  ctx.save(); ctx.fillStyle='#fff'; ctx.globalAlpha=0.06;\n  ctx.beginPath();\n  ctx.moveTo(carX+carW*.16,carY+carH*.4);\n  ctx.lineTo(carX+carW*.3,carY+carH*.2);\n  ctx.lineTo(carX+carW*.38,carY+carH*.18);\n  ctx.lineTo(carX+carW*.36,carY+carH*.38);\n  ctx.closePath(); ctx.fill(); ctx.restore();\n\n  \/\/ headlights\n  ctx.fillStyle='#fffae0';\n  ctx.save(); ctx.shadowColor='#fffae0'; ctx.shadowBlur=15;\n  ctx.fillRect(carX+carW*.04,carY+carH*.48,carW*.07,carH*.12);\n  ctx.restore();\n  strokeRect(ctx,carX+carW*.04,carY+carH*.48,carW*.07,carH*.12,2);\n  ctx.fillStyle='#1a1a2a'; ctx.fillRect(carX+carW*.06,carY+carH*.5,carW*.04,carH*.04);\/\/ DRL line\n  ctx.fillStyle='#fffae0'; ctx.fillRect(carX+carW*.06,carY+carH*.5,carW*.04,carH*.01);\n\n  \/\/ taillights\n  ctx.save(); ctx.fillStyle='#c0001a'; ctx.shadowColor='#ff2244'; ctx.shadowBlur=10;\n  ctx.fillRect(carX+carW*.88,carY+carH*.46,carW*.07,carH*.14); ctx.restore();\n  strokeRect(ctx,carX+carW*.88,carY+carH*.46,carW*.07,carH*.14,2);\n\n  \/\/ wheels\n  [[.16,carH*.74],[.76,carH*.74]].forEach(([wx,wy])=>{\n    ctx.fillStyle='#0a0a12'; ctx.beginPath(); ctx.arc(carX+carW*wx,carY+wy,carH*.14,0,Math.PI*2); ctx.fill();\n    ctx.fillStyle='#1a1a2a'; ctx.beginPath(); ctx.arc(carX+carW*wx,carY+wy,carH*.1,0,Math.PI*2); ctx.fill();\n    ctx.fillStyle='#2a2a3a'; ctx.beginPath(); ctx.arc(carX+carW*wx,carY+wy,carH*.06,0,Math.PI*2); ctx.fill();\n    ctx.strokeStyle='#3a3a4a'; ctx.lineWidth=1.5;\n    for(let s=0;s<5;s++){ const a=s*Math.PI*2\/5; ctx.beginPath(); ctx.moveTo(carX+carW*wx,carY+wy); ctx.lineTo(carX+carW*wx+Math.cos(a)*carH*.09,carY+wy+Math.sin(a)*carH*.09); ctx.stroke(); }\n    ctx.fillStyle='#c8c4b0'; ctx.beginPath(); ctx.arc(carX+carW*wx,carY+wy,carH*.02,0,Math.PI*2); ctx.fill();\n  });\n\n  \/\/ BMW logo on hood\n  ctx.save();\n  ctx.strokeStyle='#c8a832'; ctx.lineWidth=1.5;\n  ctx.beginPath(); ctx.arc(carX+carW*.88,carY+carH*.42,carH*.025,0,Math.PI*2); ctx.stroke();\n  ctx.restore();\n\n  \/\/ manga speed lines from car (subtle)\n  ctx.save(); ctx.strokeStyle='#0a0a12'; ctx.lineWidth=.5; ctx.globalAlpha=0.04;\n  for(let i=0;i<8;i++){\n    ctx.beginPath();\n    ctx.moveTo(carX,carY+carH*.4+i*carH*.04);\n    ctx.lineTo(carX+carW*.15,carY+carH*.4+i*carH*.04);\n    ctx.stroke();\n  }\n  ctx.restore();\n\n  \/\/ TREES \/ BAMBOO left\n  ctx.save();\n  const treePositions=[W*.88,W*.93,W*.97];\n  treePositions.forEach(tx=>{\n    ctx.fillStyle='#0a1a0a'; ctx.fillRect(tx-W*.005,H*.28,W*.012,H*.34);\n    \/\/ bamboo nodes\n    for(let n=0;n<5;n++){\n      ctx.fillStyle='#121e12'; ctx.fillRect(tx-W*.007,H*.28+n*H*.07,W*.015,H*.01);\n    }\n    \/\/ leaves\n    ctx.fillStyle='#0f1e0f'; ctx.globalAlpha=0.8;\n    ctx.beginPath(); ctx.ellipse(tx,H*.28,W*.04,H*.06,-.3,0,Math.PI*2); ctx.fill();\n    ctx.beginPath(); ctx.ellipse(tx+W*.02,H*.25,W*.03,H*.05,.3,0,Math.PI*2); ctx.fill();\n  });\n  ctx.restore();\n\n  \/\/ SIGN — neon style\n  ctx.fillStyle='#0a0a12'; ctx.fillRect(W*.68,H*.12,W*.25,H*.08);\n  strokeRect(ctx,W*.68,H*.12,W*.25,H*.08,2);\n  mangaText(ctx,'DSTRCT',W*.7,H*.18,H*.05,'#e85c00');\n  ctx.save(); ctx.fillStyle='#e85c00'; ctx.globalAlpha=0.12;\n  ctx.fillRect(W*.68,H*.12,W*.25,H*.08); ctx.restore();\n\n  \/\/ cherry blossom petals floating\n  ctx.save(); ctx.fillStyle='#f0c0c8'; ctx.globalAlpha=0.6;\n  [[.15,.3],[.6,.2],[.82,.35],[.3,.42],[.72,.28],[.1,.5]].forEach(([px,py])=>{\n    ctx.beginPath(); ctx.ellipse(W*px,H*py,W*.008,W*.005,.5,0,Math.PI*2); ctx.fill();\n    ctx.beginPath(); ctx.ellipse(W*px+W*.01,H*py+H*.01,W*.008,W*.005,-.3,0,Math.PI*2); ctx.fill();\n  });\n  ctx.restore();\n}\n\n\/* ── LIVING ROOM ── *\/\nfunction drawLivingRoom(ctx, W, H){\n  \/\/ floor — tatami\n  const floor = ctx.createLinearGradient(0,H*.55,0,H);\n  floor.addColorStop(0,'#8a7a5a'); floor.addColorStop(1,'#6a5a3a');\n  ctx.fillStyle=floor; ctx.fillRect(0,H*.55,W,H*.45);\n  \/\/ tatami grid\n  ctx.save(); ctx.strokeStyle='#5a4a2a'; ctx.lineWidth=2; ctx.globalAlpha=0.5;\n  for(let x=0;x<W;x+=W*.1) line(ctx,x,H*.55,x-W*.1,H,'#5a4a2a',1);\n  for(let y=H*.55;y<H;y+=H*.08) line(ctx,0,y,W,y,'#5a4a2a',1);\n  ctx.restore();\n\n  \/\/ walls\n  ctx.fillStyle='#e8e4d8'; ctx.fillRect(0,0,W,H*.56);\n  \/\/ wall shoji panels\n  ctx.save(); ctx.strokeStyle='#0a0a12'; ctx.lineWidth=1.5; ctx.globalAlpha=0.2;\n  for(let vx=0;vx<W;vx+=W*.08) line(ctx,vx,0,vx,H*.56,'#0a0a12',1);\n  for(let hy=0;hy<H*.56;hy+=H*.1) line(ctx,0,hy,W,hy,'#0a0a12',1);\n  ctx.restore();\n\n  \/\/ ceiling beam\n  ctx.fillStyle='#8a6a3a'; ctx.fillRect(0,0,W,H*.06);\n  strokeRect(ctx,0,0,W,H*.06,3);\n  line(ctx,W*.33,0,W*.33,H*.06,'#6a4a1a',3);\n  line(ctx,W*.66,0,W*.66,H*.06,'#6a4a1a',3);\n\n  \/\/ LARGE TV\n  const tvX=W*.3, tvY=H*.08, tvW=W*.4, tvH=H*.3;\n  ctx.fillStyle='#0a0a12'; ctx.fillRect(tvX-W*.02,tvY-H*.02,tvW+W*.04,tvH+H*.06);\n  strokeRect(ctx,tvX-W*.02,tvY-H*.02,tvW+W*.04,tvH+H*.06,3);\n  ctx.fillStyle='#050814'; ctx.fillRect(tvX,tvY,tvW,tvH);\n  \/\/ TV screen content — manga panel\n  ctx.save(); ctx.fillStyle='#0a0020'; ctx.fillRect(tvX,tvY,tvW,tvH);\n  \/\/ scanlines\n  ctx.strokeStyle='#ffffff'; ctx.lineWidth=.5; ctx.globalAlpha=0.03;\n  for(let sy=tvY;sy<tvY+tvH;sy+=3) line(ctx,tvX,sy,tvX+tvW,sy,'#fff',.5);\n  ctx.restore();\n  \/\/ PLAY icon on TV\n  ctx.save(); ctx.fillStyle='#c0001a'; ctx.globalAlpha=0.8;\n  ctx.beginPath(); ctx.moveTo(tvX+tvW*.44,tvY+tvH*.35); ctx.lineTo(tvX+tvW*.44,tvY+tvH*.65); ctx.lineTo(tvX+tvW*.62,tvY+tvH*.5); ctx.closePath(); ctx.fill(); ctx.restore();\n  ctx.save(); ctx.strokeStyle='#c0001a'; ctx.lineWidth=3; ctx.globalAlpha=0.6;\n  ctx.beginPath(); ctx.arc(tvX+tvW*.5,tvY+tvH*.5,tvH*.18,0,Math.PI*2); ctx.stroke(); ctx.restore();\n  \/\/ LATEST DROP label on TV\n  mangaText(ctx,'LATEST DROP',tvX+tvW*.08,tvY+tvH*.25,tvH*.09,'#e85c00');\n  \/\/ TV stand\n  ctx.fillStyle='#1a1a2a'; ctx.fillRect(tvX+tvW*.4,tvY+tvH,tvW*.2,H*.04);\n  ctx.fillStyle='#1a1a2a'; ctx.fillRect(tvX+tvW*.25,tvY+tvH+H*.04,tvW*.5,H*.02);\n\n  \/\/ SOFA — low Japanese style\n  const sofaX=W*.2, sofaY=H*.6;\n  ctx.fillStyle='#1a1830'; ctx.fillRect(sofaX,sofaY,W*.6,H*.18);\n  ctx.fillStyle='#141226'; ctx.fillRect(sofaX,sofaY,W*.6,H*.06); \/\/ back cushion\n  strokeRect(ctx,sofaX,sofaY,W*.6,H*.18,3);\n  \/\/ cushions\n  ['#1e1a34','#1a1630','#1e1a34'].forEach((c,i)=>{\n    ctx.fillStyle=c; ctx.fillRect(sofaX+W*.02+i*W*.19,sofaY+H*.065,W*.18,H*.1);\n    strokeRect(ctx,sofaX+W*.02+i*W*.19,sofaY+H*.065,W*.18,H*.1,2);\n  });\n  \/\/ sofa legs\n  [[sofaX+W*.02,sofaY+H*.17],[sofaX+W*.56,sofaY+H*.17]].forEach(([lx,ly])=>{\n    ctx.fillStyle='#0a0a12'; ctx.fillRect(lx,ly,W*.03,H*.04);\n  });\n\n  \/\/ RECORD SHELF left wall\n  ctx.fillStyle='#8a6a3a'; ctx.fillRect(W*.02,H*.2,W*.22,H*.04);\n  strokeRect(ctx,W*.02,H*.2,W*.22,H*.04,2);\n  \/\/ records stacked\n  const recColors=['#1a0a2e','#0a1a2e','#1a1a0a','#2e0a0a','#0a2e1a'];\n  recColors.forEach((c,i)=>{\n    ctx.fillStyle=c; ctx.fillRect(W*.03+i*W*.04,H*.1,W*.035,H*.1);\n    strokeRect(ctx,W*.03+i*W*.04,H*.1,W*.035,H*.1,2);\n    \/\/ spine label\n    ctx.fillStyle='#c8a832'; ctx.fillRect(W*.03+i*W*.04+W*.005,H*.11,W*.025,H*.005);\n  });\n\n  \/\/ STAIRCASE right\n  const stairX=W*.78;\n  ctx.fillStyle='#6a5a3a';\n  for(let s=0;s<6;s++){\n    ctx.fillRect(stairX,H*.55+s*H*.07,W*.22-s*W*.02,H*.07);\n    strokeRect(ctx,stairX,H*.55+s*H*.07,W*.22-s*W*.02,H*.07,2);\n  }\n  \/\/ stair handrail\n  ctx.fillStyle='#4a3a1a';\n  line(ctx,stairX,H*.52,stairX+W*.12,H*.95,'#4a3a1a',4);\n  for(let s=0;s<6;s++) line(ctx,stairX+s*W*.018,H*.55+s*H*.065,stairX+s*W*.018,H*.95,'#4a3a1a',2);\n\n  \/\/ FRONT DOOR back (left)\n  ctx.fillStyle='#1a1020'; ctx.fillRect(W*.02,H*.28,W*.1,H*.27);\n  strokeRect(ctx,W*.02,H*.28,W*.1,H*.27,3);\n  line(ctx,W*.02,H*.37,W*.12,H*.37,'#0a0a12',2);\n  mangaText(ctx,'OUT',W*.03,H*.42,H*.04,'#666');\n\n  \/\/ HANGING LAMP\n  line(ctx,W*.5,0,W*.5,H*.08,'#0a0a12',2);\n  ctx.fillStyle='#c8a832'; ctx.beginPath(); ctx.arc(W*.5,H*.09,W*.03,0,Math.PI*2); ctx.fill();\n  ctx.save(); ctx.fillStyle='#fff8cc'; ctx.globalAlpha=0.15;\n  ctx.beginPath(); ctx.arc(W*.5,H*.09,W*.12,0,Math.PI*2); ctx.fill(); ctx.restore();\n\n  \/\/ manga text panel\n  ctx.fillStyle='#0a0a12'; ctx.fillRect(W*.01,H*.01,W*.2,H*.07);\n  mangaText(ctx,'「リビング」',W*.02,H*.065,H*.045,'#e8e4d8');\n}\n\n\/* ── HALLWAY ── *\/\nfunction drawHallway(ctx, W, H){\n  \/\/ wall\n  ctx.fillStyle='#d4cfc0'; ctx.fillRect(0,0,W,H);\n  \/\/ ceiling\n  ctx.fillStyle='#c8c3b4'; ctx.fillRect(0,0,W,H*.12);\n  strokeRect(ctx,0,0,W,H*.12,3);\n  \/\/ floor\n  const floorGrad=ctx.createLinearGradient(0,H*.78,0,H);\n  floorGrad.addColorStop(0,'#7a6a4a'); floorGrad.addColorStop(1,'#5a4a2a');\n  ctx.fillStyle=floorGrad; ctx.fillRect(0,H*.78,W,H*.22);\n  \/\/ perspective floor lines\n  ctx.save(); ctx.strokeStyle='#4a3a1a'; ctx.lineWidth=1; ctx.globalAlpha=0.4;\n  for(let fx=0;fx<W;fx+=W*.1) line(ctx,fx,H*.78,W*.5+(fx-W*.5)*.1,H*.95,'#4a3a1a',1);\n  line(ctx,0,H*.88,W,H*.88,'#4a3a1a',1);\n  ctx.restore();\n\n  \/\/ wall panel wainscoting\n  ctx.save(); ctx.strokeStyle='#b8b3a4'; ctx.lineWidth=2;\n  for(let px=W*.02;px<W;px+=W*.1){ ctx.strokeRect(px,H*.2,W*.08,H*.5); }\n  ctx.restore();\n\n  \/\/ overhead light strip\n  ctx.fillStyle='#fff8cc'; ctx.fillRect(W*.3,H*.08,W*.4,H*.02);\n  ctx.save(); ctx.fillStyle='#fff8cc'; ctx.globalAlpha=0.1;\n  ctx.fillRect(0,0,W,H*.3); ctx.restore();\n\n  \/\/ THREE DOORS\n  const doorH = H*.68, doorW = W*.18, doorY = H*.1;\n  const doors = [\n    {x:W*.1, label:'MY ROOM', jp:'部屋', color:'#1a1020', light:'#aa88ff'},\n    {x:W*.41, label:'STUDIO', jp:'スタジオ', color:'#0a1a0a', light:'#88ff99'},\n    {x:W*.72, label:'GAMING', jp:'ゲーム', color:'#0a0a1a', light:'#88aaff'},\n  ];\n\n  doors.forEach(d=>{\n    \/\/ door frame\n    ctx.fillStyle='#8a6a3a'; ctx.fillRect(d.x-W*.01,doorY-H*.01,doorW+W*.02,doorH+H*.02);\n    \/\/ door body\n    ctx.fillStyle=d.color; ctx.fillRect(d.x,doorY,doorW,doorH);\n    strokeRect(ctx,d.x,doorY,doorW,doorH,3);\n    \/\/ door panels\n    line(ctx,d.x,doorY+doorH*.35,d.x+doorW,doorY+doorH*.35,d.color==='#1a1020'?'#2a1a30':'#0f1a0f',2);\n    line(ctx,d.x,doorY+doorH*.7,d.x+doorW,doorY+doorH*.7,d.color==='#1a1020'?'#2a1a30':'#0f1a0f',2);\n    \/\/ door knob\n    ctx.save(); ctx.fillStyle='#c8a832'; ctx.shadowColor=d.light; ctx.shadowBlur=8;\n    ctx.beginPath(); ctx.arc(d.x+doorW*.75,doorY+doorH*.52,W*.012,0,Math.PI*2); ctx.fill(); ctx.restore();\n    \/\/ light under door\n    ctx.save(); ctx.fillStyle=d.light; ctx.globalAlpha=0.15;\n    ctx.fillRect(d.x+2,doorY+doorH*.95,doorW-4,doorH*.03); ctx.restore();\n    \/\/ label plaque\n    ctx.fillStyle='#c8a832'; ctx.fillRect(d.x+doorW*.15,doorY+doorH*.08,doorW*.7,doorH*.12);\n    strokeRect(ctx,d.x+doorW*.15,doorY+doorH*.08,doorW*.7,doorH*.12,2);\n    mangaText(ctx,d.label,d.x+doorW*.18,doorY+doorH*.18,doorH*.08,'#0a0a12');\n    \/\/ jp\n    ctx.save(); ctx.font=`700 ${doorH*.05}px 'Noto Sans JP'`; ctx.fillStyle='#0a0a12';\n    ctx.fillText(d.jp,d.x+doorW*.25,doorY+doorH*.25); ctx.restore();\n  });\n\n  \/\/ staircase down\n  ctx.fillStyle='#6a5a3a'; ctx.fillRect(W*.88,H*.6,W*.11,H*.3);\n  for(let s=0;s<4;s++){ line(ctx,W*.88,H*.6+s*H*.075,W*.99,H*.6+s*H*.075,'#0a0a12',2); }\n  mangaText(ctx,'↓',W*.89,H*.86,H*.1,'#0a0a12');\n  mangaText(ctx,'DOWN',W*.87,H*.95,H*.05,'#888');\n\n  \/\/ manga panel label\n  ctx.fillStyle='#0a0a12'; ctx.fillRect(0,0,W*.24,H*.1);\n  mangaText(ctx,'「2階廊下」',W*.01,H*.08,H*.065,'#e8e4d8');\n}\n\n\/* ── BEDROOM ── *\/\nfunction drawBedroom(ctx, W, H){\n  \/\/ floor wood\n  ctx.fillStyle='#5a3a1a'; ctx.fillRect(0,H*.6,W,H*.4);\n  ctx.save(); ctx.strokeStyle='#4a2a0a'; ctx.lineWidth=1; ctx.globalAlpha=0.5;\n  for(let flx=0;flx<W;flx+=W*.12) line(ctx,flx,H*.6,flx,H,'#4a2a0a',1);\n  for(let fly=H*.6;fly<H;fly+=H*.06) line(ctx,0,fly,W,fly,'#4a2a0a',.5);\n  ctx.restore();\n\n  \/\/ walls\n  ctx.fillStyle='#e8e4d8'; ctx.fillRect(0,0,W,H*.61);\n  \/\/ accent wall stripe\n  ctx.fillStyle='#d4cfc0'; ctx.fillRect(W*.6,0,W*.4,H*.61);\n  line(ctx,W*.6,0,W*.6,H*.61,'#0a0a12',3);\n\n  \/\/ ceiling\n  ctx.fillStyle='#c8c3b4'; ctx.fillRect(0,0,W,H*.06);\n  strokeRect(ctx,0,0,W,H*.06,3);\n\n  \/\/ WINDOW left wall\n  ctx.fillStyle='#7ab8e8'; ctx.fillRect(W*.06,H*.12,W*.18,H*.24);\n  strokeRect(ctx,W*.06,H*.12,W*.18,H*.24,3);\n  line(ctx,W*.15,H*.12,W*.15,H*.36,'#0a0a12',2);\n  line(ctx,W*.06,H*.24,W*.24,H*.24,'#0a0a12',2);\n  \/\/ night outside\n  ctx.fillStyle='#050820'; ctx.fillRect(W*.065,H*.125,W*.168,H*.228);\n  \/\/ stars outside\n  ctx.save(); ctx.fillStyle='#fff'; ctx.globalAlpha=0.6;\n  [[.09,.15],[.13,.18],[.19,.14],[.17,.22],[.1,.27]].forEach(([sx,sy])=>{\n    ctx.beginPath(); ctx.arc(W*sx,H*sy,1.5,0,Math.PI*2); ctx.fill();\n  });\n  ctx.restore();\n\n  \/\/ DESK + PC\n  ctx.fillStyle='#3a2a0a'; ctx.fillRect(W*.06,H*.44,W*.3,H*.12);\n  strokeRect(ctx,W*.06,H*.44,W*.3,H*.12,3);\n  \/\/ monitor\n  ctx.fillStyle='#0a0a12'; ctx.fillRect(W*.1,H*.22,W*.22,H*.22);\n  strokeRect(ctx,W*.1,H*.22,W*.22,H*.22,3);\n  ctx.fillStyle='#050814'; ctx.fillRect(W*.11,H*.23,W*.2,H*.2);\n  \/\/ screen glow + code\n  ctx.save(); ctx.globalAlpha=0.8;\n  ctx.fillStyle='#0d0b20'; ctx.fillRect(W*.11,H*.23,W*.2,H*.2);\n  ctx.fillStyle='#c8ff00'; ctx.fillRect(W*.12,H*.25,W*.08,H*.01);\n  const codeColors=['#5544aa','#c8ff00','#ff7700','#5544aa','#aa4488'];\n  for(let cl=0;cl<6;cl++){\n    ctx.fillStyle=codeColors[cl%codeColors.length];\n    ctx.globalAlpha=0.4+Math.random()*.3;\n    ctx.fillRect(W*.12,H*.27+cl*H*.02,W*.04+Math.random()*W*.12,H*.008);\n  }\n  ctx.restore();\n  \/\/ monitor stand\n  ctx.fillStyle='#1a1a2a'; ctx.fillRect(W*.19,H*.44,W*.04,H*.02);\n  ctx.fillStyle='#1a1a2a'; ctx.fillRect(W*.16,H*.46,W*.1,H*.01);\n\n  \/\/ VINYL record on wall\n  ctx.save();\n  const vX=W*.36,vY=H*.2,vR=W*.06;\n  ctx.fillStyle='#0a0810'; ctx.beginPath(); ctx.arc(vX,vY,vR,0,Math.PI*2); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=2; ctx.stroke();\n  ctx.fillStyle='#1a1630'; ctx.beginPath(); ctx.arc(vX,vY,vR*.7,0,Math.PI*2); ctx.fill();\n  ctx.fillStyle='#0a0810'; ctx.beginPath(); ctx.arc(vX,vY,vR*.4,0,Math.PI*2); ctx.fill();\n  ctx.fillStyle='#1e1a34'; ctx.beginPath(); ctx.arc(vX,vY,vR*.2,0,Math.PI*2); ctx.fill();\n  ctx.fillStyle='#c8a832'; ctx.beginPath(); ctx.arc(vX,vY,vR*.05,0,Math.PI*2); ctx.fill();\n  ctx.restore();\n\n  \/\/ BED — low Japanese futon style\n  ctx.fillStyle='#1a1828'; ctx.fillRect(W*.5,H*.52,W*.46,H*.22);\n  strokeRect(ctx,W*.5,H*.52,W*.46,H*.22,3);\n  ctx.fillStyle='#141224'; ctx.fillRect(W*.5,H*.52,W*.46,H*.04); \/\/ headboard\n  \/\/ pillow\n  ctx.fillStyle='#201c38'; ctx.fillRect(W*.52,H*.54,W*.15,H*.09);\n  strokeRect(ctx,W*.52,H*.54,W*.15,H*.09,2);\n  \/\/ duvet lines\n  ctx.save(); ctx.strokeStyle='#1e1a30'; ctx.lineWidth=1;\n  for(let dl=0;dl<4;dl++) line(ctx,W*.5,H*(.56+dl*.04),W*.96,H*(.56+dl*.04),'#1e1a30',1);\n  ctx.restore();\n\n  \/\/ ROTTWEILER (manga style)\n  const dogX=W*.55, dogY=H*.68, dogW=W*.22, dogH=H*.2;\n  ctx.save();\n  \/\/ dog body\n  ctx.fillStyle='#1a0a04';\n  ctx.beginPath();\n  ctx.ellipse(dogX+dogW*.5,dogY+dogH*.55,dogW*.45,dogH*.3,0,0,Math.PI*2); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=2; ctx.stroke();\n  \/\/ dog head\n  ctx.fillStyle='#2a1208';\n  ctx.beginPath(); ctx.arc(dogX+dogW*.8,dogY+dogH*.3,dogW*.22,0,Math.PI*2); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=2; ctx.stroke();\n  \/\/ snout\n  ctx.fillStyle='#3a1a0a';\n  ctx.beginPath(); ctx.arc(dogX+dogW*.97,dogY+dogH*.35,dogW*.12,0,Math.PI*2); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=1.5; ctx.stroke();\n  \/\/ nose\n  ctx.fillStyle='#0a0a12';\n  ctx.beginPath(); ctx.arc(dogX+dogW*1.06,dogY+dogH*.33,dogW*.04,0,Math.PI*2); ctx.fill();\n  \/\/ eyes — manga style (glowing)\n  ctx.fillStyle='#ff4400';\n  ctx.beginPath(); ctx.arc(dogX+dogW*.85,dogY+dogH*.25,dogW*.035,0,Math.PI*2); ctx.fill();\n  ctx.fillStyle='#0a0a12';\n  ctx.beginPath(); ctx.arc(dogX+dogW*.85,dogY+dogH*.25,dogW*.018,0,Math.PI*2); ctx.fill();\n  ctx.fillStyle='#fff';\n  ctx.beginPath(); ctx.arc(dogX+dogW*.855,dogY+dogH*.245,dogW*.008,0,Math.PI*2); ctx.fill();\n  \/\/ eye glow\n  ctx.save(); ctx.fillStyle='#ff4400'; ctx.globalAlpha=0.2;\n  ctx.beginPath(); ctx.arc(dogX+dogW*.85,dogY+dogH*.25,dogW*.06,0,Math.PI*2); ctx.fill(); ctx.restore();\n  \/\/ ears — floppy rottweiler\n  ctx.fillStyle='#1a0804';\n  ctx.beginPath(); ctx.moveTo(dogX+dogW*.7,dogY+dogH*.15); ctx.lineTo(dogX+dogW*.65,dogY+dogH*.35); ctx.lineTo(dogX+dogW*.8,dogY+dogH*.18); ctx.closePath(); ctx.fill();\n  ctx.strokeStyle='#0a0a12'; ctx.lineWidth=1.5; ctx.stroke();\n  \/\/ tan markings\n  ctx.fillStyle='#8a5a2a'; ctx.globalAlpha=0.7;\n  ctx.beginPath(); ctx.arc(dogX+dogW*.92,dogY+dogH*.3,dogW*.06,0,Math.PI*2); ctx.fill(); \/\/ eyebrow dots\n  ctx.beginPath(); ctx.arc(dogX+dogW*.97,dogY+dogH*.38,dogW*.08,0,Math.PI*2); ctx.fill(); \/\/ muzzle tan\n  ctx.restore();\n  \/\/ paws\n  ctx.fillStyle='#1a0a04';\n  [[dogX+dogW*.1,dogY+dogH*.82],[dogX+dogW*.3,dogY+dogH*.85],[dogX+dogW*.6,dogY+dogH*.85]].forEach(([px,py])=>{\n    ctx.beginPath(); ctx.ellipse(px,py,dogW*.09,dogH*.07,0,0,Math.PI*2); ctx.fill();\n    ctx.strokeStyle='#0a0a12'; ctx.lineWidth=1.5; ctx.stroke();\n  });\n  \/\/ collar\n  ctx.save(); ctx.strokeStyle='#c0001a'; ctx.lineWidth=W*.008;\n  ctx.beginPath(); ctx.arc(dogX+dogW*.8,dogY+dogH*.4,dogW*.16,-.5,Math.PI*.7); ctx.stroke();\n  ctx.fillStyle='#c8a832'; ctx.beginPath(); ctx.arc(dogX+dogW*.82,dogY+dogH*.55,dogW*.03,0,Math.PI*2); ctx.fill();\n  ctx.restore();\n  \/\/ manga action lines around dog\n  ctx.save(); ctx.strokeStyle='#0a0a12'; ctx.lineWidth=.5; ctx.globalAlpha=0.07;\n  for(let ml=0;ml<12;ml++){\n    const a=ml*Math.PI*2\/12;\n    ctx.beginPath(); ctx.moveTo(dogX+dogW*.75,dogY+dogH*.5); ctx.lineTo(dogX+dogW*.75+Math.cos(a)*W*.15,dogY+dogH*.5+Math.sin(a)*H*.15); ctx.stroke();\n  }\n  ctx.restore();\n\n  \/\/ POSTER right wall\n  ctx.fillStyle='#0a0820'; ctx.fillRect(W*.64,H*.1,W*.18,H*.28);\n  strokeRect(ctx,W*.64,H*.1,W*.18,H*.28,3);\n  \/\/ poster art — silhouettes\n  ctx.fillStyle='#0f0a2a'; ctx.fillRect(W*.65,H*.11,W*.16,H*.26);\n  \/\/ silhouette figures\n  ['#c0001a','#e85c00','#1a2a6c'].forEach((c,i)=>{\n    ctx.fillStyle=c; ctx.globalAlpha=0.7;\n    ctx.fillRect(W*(.67+i*.04),H*.24,W*.024,H*.1);\n    ctx.beginPath(); ctx.arc(W*(.682+i*.04),H*.23,W*.014,0,Math.PI*2); ctx.fill();\n  });\n  ctx.globalAlpha=1;\n  mangaText(ctx,'THE CREW',W*.645,H*.32,H*.04,'#e8e4d8');\n  mangaText(ctx,'DSTRCT',W*.65,H*.36,H*.04,'#c0001a');\n  \/\/ frame\n  ctx.fillStyle='#8a6a3a'; ctx.fillRect(W*.63,H*.09,W*.2,H*.3);\n  ctx.fillStyle='#0a0820'; ctx.fillRect(W*.64,H*.1,W*.18,H*.28);\n  strokeRect(ctx,W*.63,H*.09,W*.2,H*.3,4);\n\n  \/\/ DOOR right\n  ctx.fillStyle='#1a1020'; ctx.fillRect(W*.89,H*.28,W*.1,H*.35);\n  strokeRect(ctx,W*.89,H*.28,W*.1,H*.35,3);\n  mangaText(ctx,'←',W*.9,H*.48,H*.06,'#888');\n\n  \/\/ shelves\n  ctx.fillStyle='#6a4a1a'; ctx.fillRect(W*.28,H*.44,W*.18,H*.03);\n  strokeRect(ctx,W*.28,H*.44,W*.18,H*.03,2);\n  [['#c0001a'],['#0a1020'],['#1a0a20']].forEach(([c],i)=>{\n    ctx.fillStyle=c; ctx.fillRect(W*(.29+i*.055),H*.34,W*.04,H*.1);\n    strokeRect(ctx,W*(.29+i*.055),H*.34,W*.04,H*.1,1.5);\n  });\n\n  \/\/ manga label\n  ctx.fillStyle='#0a0a12'; ctx.fillRect(0,0,W*.22,H*.1);\n  mangaText(ctx,'「部屋」',W*.01,H*.075,H*.065,'#e8e4d8');\n}\n\n\/* ── STUDIO ── *\/\nfunction drawStudio(ctx, W, H){\n  \/\/ floor\n  ctx.fillStyle='#0e140c'; ctx.fillRect(0,H*.68,W,H*.32);\n  ctx.save(); ctx.strokeStyle='#162014'; ctx.lineWidth=1; ctx.globalAlpha=0.5;\n  for(let fx=0;fx<W;fx+=W*.1) line(ctx,fx,H*.68,W*.5+(fx-W*.5)*.2,H,'#162014',1);\n  for(let fy=H*.68;fy<H;fy+=H*.08) line(ctx,0,fy,W,fy,'#162014',.8);\n  ctx.restore();\n\n  \/\/ walls — dark acoustic treatment\n  ctx.fillStyle='#0c1210'; ctx.fillRect(0,0,W,H*.69);\n  \/\/ acoustic panels\n  ctx.save(); ctx.globalAlpha=0.8;\n  const panelColors=['#0f180e','#121e10','#0e160c'];\n  for(let px=0;px<W;px+=W*.08){\n    for(let py=H*.04;py<H*.68;py+=H*.08){\n      ctx.fillStyle=panelColors[Math.floor(Math.random()*3)];\n      ctx.fillRect(px+W*.005,py+H*.005,W*.07,H*.07);\n    }\n  }\n  ctx.restore();\n  \/\/ LED strip ceiling\n  ctx.fillStyle='#001a08'; ctx.fillRect(0,0,W,H*.04);\n  ctx.save(); ctx.fillStyle='#00ff6a'; ctx.globalAlpha=0.12; ctx.fillRect(0,0,W,H*.04); ctx.restore();\n\n  \/\/ CITY WINDOW center\n  const winX=W*.28, winY=H*.04, winW=W*.44, winH=H*.38;\n  ctx.fillStyle='#040a06'; ctx.fillRect(winX,winY,winW,winH);\n  strokeRect(ctx,winX,winY,winW,winH,4);\n  \/\/ night city\n  const cityGrad=ctx.createLinearGradient(0,winY,0,winY+winH);\n  cityGrad.addColorStop(0,'#030610'); cityGrad.addColorStop(1,'#050c08');\n  ctx.fillStyle=cityGrad; ctx.fillRect(winX+3,winY+3,winW-6,winH-6);\n  \/\/ building silhouettes\n  ctx.fillStyle='#060e08';\n  const bldgs=[[.3,.6,.06,.4],[.37,.5,.05,.5],[.43,.55,.07,.45],[.51,.45,.06,.55],[.58,.6,.05,.4],[.64,.5,.08,.5],[.72,.55,.06,.45]];\n  bldgs.forEach(([bx,bh,bw,by])=>ctx.fillRect(winX+winW*bx,winY+winH*by,winW*bw,winH*bh));\n  \/\/ city lights\n  ctx.save(); ctx.fillStyle='#c8ff00'; ctx.globalAlpha=0.5;\n  [[.33,.62],[.35,.55],[.39,.52],[.45,.58],[.53,.47],[.57,.6],[.65,.52],[.71,.57]].forEach(([lx,ly])=>{\n    ctx.fillRect(winX+winW*lx,winY+winH*ly,3,3);\n  });\n  ctx.restore();\n  \/\/ window bars\n  line(ctx,winX+winW*.5,winY,winX+winW*.5,winY+winH,'#162014',3);\n  line(ctx,winX,winY+winH*.5,winX+winW,winY+winH*.5,'#162014',3);\n\n  \/\/ CREW POSTER left\n  ctx.fillStyle='#0a1008'; ctx.fillRect(W*.03,H*.28,W*.18,H*.28);\n  strokeRect(ctx,W*.03,H*.28,W*.18,H*.28,3);\n  \/\/ pixel photo feel\n  ctx.save();\n  ['#1a2040','#2a1a40','#1a3040'].forEach((c,i)=>{\n    ctx.fillStyle=c; ctx.fillRect(W*(.05+i*.04),H*.3,W*.03,H*.2);\n    ctx.fillStyle=i%2===0?'#8a6440':'#6a4430';\n    ctx.beginPath(); ctx.arc(W*(.065+i*.04),H*.31,W*.018,0,Math.PI*2); ctx.fill();\n  });\n  ctx.restore();\n  mangaText(ctx,'CREW',W*.055,H*.52,H*.05,'#00ff6a');\n  mangaText(ctx,'NIGHTS',W*.04,H*.58,H*.04,'#c8a832');\n  \/\/ frame\n  ctx.fillStyle='#1a2a18'; ctx.fillRect(W*.02,H*.27,W*.2,H*.3);\n  ctx.fillStyle='#0a1008'; ctx.fillRect(W*.03,H*.28,W*.18,H*.28);\n  strokeRect(ctx,W*.02,H*.27,W*.2,H*.3,4);\n\n  \/\/ MIXING BOARD\n  const mbX=W*.22, mbY=H*.5, mbW=W*.56, mbH=H*.2;\n  ctx.fillStyle='#0a1208'; ctx.fillRect(mbX,mbY,mbW,mbH);\n  strokeRect(ctx,mbX,mbY,mbW,mbH,3);\n  ctx.fillStyle='#0c1510'; ctx.fillRect(mbX+W*.01,mbY+H*.01,mbW-W*.02,mbH-H*.02);\n  \/\/ faders\n  const faderCount=18;\n  for(let f=0;f<faderCount;f++){\n    const fx=mbX+W*.02+f*(mbW-W*.04)\/faderCount;\n    ctx.strokeStyle='#1e3020'; ctx.lineWidth=2;\n    ctx.beginPath(); ctx.moveTo(fx,mbY+H*.03); ctx.lineTo(fx,mbY+mbH*.75); ctx.stroke();\n    \/\/ fader knob at random height\n    const fy=mbY+H*.03+(mbH*.72-H*.02)*Math.random();\n    ctx.fillStyle='#c8ff00'; ctx.globalAlpha=0.7;\n    ctx.fillRect(fx-W*.006,fy,W*.012,H*.02);\n    ctx.globalAlpha=1;\n  }\n  \/\/ VU meters\n  for(let v=0;v<4;v++){\n    const vx=mbX+W*.01+v*W*.014;\n    ctx.fillStyle='#001a08'; ctx.fillRect(vx,mbY+H*.02,W*.01,mbH*.7);\n    const lvl=0.4+Math.random()*.5;\n    const grad=ctx.createLinearGradient(0,mbY+mbH*.7*(1-lvl),0,mbY+mbH*.7);\n    grad.addColorStop(0,'#ff2d2d'); grad.addColorStop(0.3,'#e85c00'); grad.addColorStop(1,'#00ff6a');\n    ctx.fillStyle=grad; ctx.fillRect(vx,mbY+mbH*.7*(1-lvl),W*.01,mbH*.7*lvl);\n  }\n  \/\/ knobs\n  ctx.save();\n  for(let k=0;k<12;k++){\n    const kx=mbX+W*.03+k*(mbW*.8\/12);\n    ctx.fillStyle='#162018'; ctx.strokeStyle='#1e3020'; ctx.lineWidth=1;\n    ctx.beginPath(); ctx.arc(kx,mbY+mbH*.88,W*.01,0,Math.PI*2); ctx.fill(); ctx.stroke();\n    ctx.strokeStyle='#c8ff00'; ctx.globalAlpha=0.5;\n    ctx.beginPath(); ctx.moveTo(kx,mbY+mbH*.88); ctx.lineTo(kx+Math.cos(k*.4)*W*.009,mbY+mbH*.88+Math.sin(k*.4)*W*.009); ctx.stroke();\n    ctx.globalAlpha=1;\n  }\n  ctx.restore();\n\n  \/\/ STUDIO MONITORS\n  [[W*.04,H*.38],[W*.79,H*.38]].forEach(([sx,sy])=>{\n    ctx.fillStyle='#0a110a'; ctx.fillRect(sx,sy,W*.14,H*.22); strokeRect(ctx,sx,sy,W*.14,H*.22,3);\n    ctx.fillStyle='#080e08'; ctx.fillRect(sx+W*.015,sy+H*.015,W*.11,H*.12);\n    ctx.fillStyle='#0a100a';\n    ctx.beginPath(); ctx.arc(sx+W*.07,sy+H*.08,W*.04,0,Math.PI*2); ctx.fill();\n    ctx.strokeStyle='#162014'; ctx.lineWidth=2; ctx.stroke();\n    ctx.fillStyle='#060c06'; ctx.beginPath(); ctx.arc(sx+W*.07,sy+H*.08,W*.025,0,Math.PI*2); ctx.fill();\n    \/\/ green glow from speakers\n    ctx.save(); ctx.fillStyle='#00ff6a'; ctx.globalAlpha=0.05;\n    ctx.beginPath(); ctx.arc(sx+W*.07,sy+H*.08,W*.07,0,Math.PI*2); ctx.fill(); ctx.restore();\n    \/\/ tweeter\n    ctx.fillStyle='#162014'; ctx.beginPath(); ctx.arc(sx+W*.07,sy+H*.17,W*.015,0,Math.PI*2); ctx.fill();\n  });\n\n  \/\/ MIC STAND center\n  line(ctx,W*.58,H*.28,W*.58,H*.5,'#1a2018',3);\n  line(ctx,W*.53,H*.28,W*.63,H*.28,'#1a2018',2);\n  ctx.fillStyle='#1e2a1a'; ctx.fillRect(W*.57,H*.15,W*.02,H*.14);\n  ctx.fillStyle='#1a2416'; ctx.fillRect(W*.555,H*.1,W*.03,H*.06); strokeRect(ctx,W*.555,H*.1,W*.03,H*.06,2);\n  \/\/ REC light\n  ctx.save(); ctx.fillStyle='#ff2d2d'; ctx.shadowColor='#ff2d2d'; ctx.shadowBlur=15;\n  ctx.beginPath(); ctx.arc(W*.74,H*.5,W*.012,0,Math.PI*2); ctx.fill(); ctx.restore();\n  mangaText(ctx,'REC',W*.755,H*.51,H*.04,'#ff2d2d');\n\n  \/\/ DOOR right\n  ctx.fillStyle='#0a1a0a'; ctx.fillRect(W*.9,H*.3,W*.09,H*.38);\n  strokeRect(ctx,W*.9,H*.3,W*.09,H*.38,3);\n  mangaText(ctx,'←',W*.91,H*.52,H*.07,'#888');\n\n  \/\/ manga label\n  ctx.fillStyle='#0a0a12'; ctx.fillRect(0,0,W*.22,H*.1);\n  mangaText(ctx,'「スタジオ」',W*.01,H*.075,H*.06,'#00ff6a');\n}\n\n\/* ── GAMING ROOM ── *\/\nfunction drawGaming(ctx, W, H){\n  \/\/ dark blue walls — night gaming vibe\n  ctx.fillStyle='#080a18'; ctx.fillRect(0,0,W,H);\n  \/\/ floor — dark carpet\n  ctx.fillStyle='#0a0c1e'; ctx.fillRect(0,H*.72,W,H*.28);\n  ctx.save(); ctx.strokeStyle='#12162a'; ctx.lineWidth=1; ctx.globalAlpha=0.5;\n  for(let fy=H*.72;fy<H;fy+=H*.07) line(ctx,0,fy,W,fy,'#12162a',1);\n  ctx.restore();\n  \/\/ ceiling\n  ctx.fillStyle='#060812'; ctx.fillRect(0,0,W,H*.07);\n  \/\/ LED strip ceiling — rgb\n  ctx.save();\n  const ledGrad=ctx.createLinearGradient(0,0,W,0);\n  ledGrad.addColorStop(0,'#ff0040'); ledGrad.