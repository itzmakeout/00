 \/\/ scan glow\n  ctx.save(); ctx.fillStyle='#8800ff'; ctx.globalAlpha=0.04; ctx.fillRect(monX,monY,monW,monH); ctx.restore();\n\n  \/\/ monitor stand\n  ctx.fillStyle='#0a0a1a'; ctx.fillRect(monX+monW*.43,monY+monH,monW*.14,H*.04);\n  ctx.fillStyle='#0a0a1a'; ctx.fillRect(monX+monW*.3,monY+monH+H*.04,monW*.4,H*.02);\n\n  \/\/ GAMING CHAIR\n  ctx.fillStyle='#0a0a1a'; ctx.fillRect(W*.38,H*.55,W*.24,H*.22);\n  strokeRect(ctx,W*.38,H*.55,W*.24,H*.22,3);\n  \/\/ red accent\n  line(ctx,W*.38,H*.56,W*.38,H*.73,'#c0001a',3);\n  line(ctx,W*.62,H*.56,W*.62,H*.73,'#c0001a',3);\n  ctx.fillStyle='#0f0f22'; ctx.fillRect(W*.4,H*.64,W*.2,H*.1);\n  strokeRect(ctx,W*.4,H*.64,W*.2,H*.1,2);\n  \/\/ armrests\n  ctx.fillStyle='#0a0a1a'; ctx.fillRect(W*.36,H*.66,W*.04,H*.06); strokeRect(ctx,W*.36,H*.66,W*.04,H*.06,2);\n  ctx.fillStyle='#0a0a1a'; ctx.fillRect(W*.6,H*.66,W*.04,H*.06); strokeRect(ctx,W*.6,H*.66,W*.04,H*.06,2);\n\n  \/\/ MANGA SHELF left\n  ctx.fillStyle='#3a2a1a'; ctx.fillRect(W*.02,H*.22,W*.14,H*.04);\n  strokeRect(ctx,W*.02,H*.22,W*.14,H*.04,2);\n  const mangaSpines=['#c0001a','#0a1020','#c8a832','#1a0a2e','#0a2e1a','#2e0a0a'];\n  mangaSpines.forEach((c,i)=>{\n    ctx.fillStyle=c; ctx.fillRect(W*(.025+i*.022),H*.1,W*.018,H*.12);\n    strokeRect(ctx,W*(.025+i*.022),H*.1,W*.018,H*.12,1.5);\n  });\n  mangaText(ctx,'MANGA',W*.022,H*.3,H*.04,'#c8a832');\n\n  \/\/ MERCH SHELF right\n  ctx.fillStyle='#3a2a1a'; ctx.fillRect(W*.84,H*.22,W*.14,H*.04);\n  strokeRect(ctx,W*.84,H*.22,W*.14,H*.04,2);\n  \/\/ folded shirts\n  ['#0a0a12','#c0001a','#1a1a2a'].forEach((c,i)=>{\n    ctx.fillStyle=c; ctx.fillRect(W*(.85+i*.04),H*.1,W*.034,H*.12);\n    strokeRect(ctx,W*(.85+i*.04),H*.1,W*.034,H*.12,2);\n    \/\/ dstrct text on shirt\n    ctx.save(); ctx.font=`600 ${H*.02}px 'Noto Sans JP'`; ctx.fillStyle='#c8ff00'; ctx.globalAlpha=0.7;\n    ctx.fillText('DX',W*(.856+i*.04),H*.17); ctx.restore();\n  });\n  mangaText(ctx,'MERCH',W*.844,H*.3,H*.04,'#8800ff');\n\n  \/\/ RGB KEYBOARD on desk\n  c